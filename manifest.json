{
  "manifest_version": 3,
  "name": "YouTube Lang Learn",
  "version": "1.0.0",
  "description": "Bilingual subtitles, A-B repeat, and dictionary for YouTube.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://*.youtube.com/*",
    "https://dictionaryapi.dev/*"
  ],
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*.youtube.com/*"],
      "js": ["src/content.tsx"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/inject.js"],
      "matches": ["https://*.youtube.com/*"]
    }
  ],
  "action": {
    "default_title": "Open Settings"
  }
}
